{
  "name": "exb-community-cli",
  "version": "1.0.2",
  "description": "A lightweight command line interface to allow Experience Builder developers to quickly import widgets published as NPM pacakges.",
  "keywords": [
    "exb-community",
    "cli",
    "experience-builder",
    "widget"
  ],
  "bin": {
    "exb-cli": "dist/index.js"
  },
  "preferGlobal": true,
  "license": "MIT",
  "author": "Lucius Creamer",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --colors --runInBand"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "degit": "^2.8.0",
    "enquirer": "^2.3.6",
    "fs-extra": "^11.3.3",
    "pacote": "^21.3.1",
    "semver": "^7.7.4",
    "validate-npm-package-name": "^7.0.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/pacote": "^11.1.8",
    "@types/semver": "^7.5.8",
    "@types/validate-npm-package-name": "^4.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.3"
  }
}